{
  "name": "vs-pkvsconf",
  "displayName": "VS_pkvsconf",
  "description": "Adds a toolbar button in Explorer to reveal the active file in Finder.",
  "version": "2.2026.11",
  "publisher": "Cmondary",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mondary/VS_pkvsconf.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:revealInFinderButton.revealActive",
    "onCommand:revealInFinderButton.refreshRootSize",
    "onCommand:revealInFinderButton.openRootFolderInFinder",
    "onCommand:revealInFinderButton.openGitHubRepo",
    "onCommand:pkvsconf.addTagToExtension",
    "onCommand:pkvsconf.codexCaptureResume",
    "onCommand:pkvsconf.codexSaveResume",
    "onCommand:pkvsconf.codexPickResume",
    "onCommand:pkvsconf.codexPickRecentSession",
    "onCommand:pkvsconf.codexSuggestSession",
    "onCommand:pkvsconf.createTagForExtension",
    "onCommand:pkvsconf.removeTagFromExtension",
    "onCommand:pkvsconf.regenerateWorkspaceTitlebarColor",
    "onCommand:pkvsconf.previewActivePage",
    "onCommand:pkvsconf.showExposedSecrets",
    "onCommand:pkvsconf.rescanSecrets",
    "onCommand:pkvsconf.commitWithSecretCheck",
    "onCommand:pkvsconf.createSkillsSymlink",
    "onCommand:pkvsconf.terminalSplitRight",
    "onCommand:pkvsconf.terminalSplitBottom",
    "onCommand:pkvsconf.terminalNewTab",
    "onCommand:pkvsconf.launchpadOpen",
    "onCommand:pkvsconf.launchpadOpenList",
    "onCommand:pkvsconf.launchpadAddCurrent",
    "onCommand:pkvsconf.launchpadAddFolder",
    "onCommand:pkvsconf.launchpadRevealInFinder",
    "onCommand:pkvsconf.launchpadToggleViewMode",
    "onCommand:pkvsconf.agentHistoryAddFromClipboard",
    "onCommand:pkvsconf.agentHistoryRun",
    "onCommand:pkvsconf.agentHistoryClear",
    "onCommand:pkvsconf.kanbanOpen",
    "onCommand:pkvsconf.kanbanOpenEditor",
    "onCommand:pkvsconf.openInDefaultBrowser",
    "onCommand:pkvsconf.addToGitignore",
    "onView:projectNotesView",
    "onView:projectIconView",
    "onView:extensionTagsView",
    "onView:launchpadExplorerView",
    "onView:agentHistoryView",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pkvsconfNotesContainer",
          "title": "Notes",
          "icon": "resources/notes-container.svg"
        }
      ],
      "auxiliarybar": [
        {
          "id": "pkvsconfRightSidebar",
          "title": "Workspace",
          "icon": "resources/workspace-container.svg"
        }
      ]
    },
    "configuration": {
      "title": "PK VS Conf",
      "properties": {
        "pkvsconf.launchpad.projects": {
          "type": "array",
          "default": [],
          "description": "Liste des projets du launchpad. Chaque entrée : { \"name\": \"MonProjet\", \"path\": \"/Users/xxx/Projet\" }"
        },
        "pkvsconf.launchpad.viewMode": {
          "type": "string",
          "default": "grid",
          "enum": [
            "grid",
            "mini"
          ],
          "description": "Mode d'affichage du Launchpad: 'grid' (tuiles) ou 'mini' (icônes 32x32 en ligne)."
        },
        "pkvsconf.launchpad.columns": {
          "type": "number",
          "default": 8,
          "minimum": 3,
          "maximum": 16,
          "description": "Nombre de colonnes dans la vue Launchpad plein écran."
        },
        "pkvsconf.launchpad.rows": {
          "type": "number",
          "default": 4,
          "minimum": 2,
          "maximum": 10,
          "description": "Nombre de lignes visibles ciblé dans la vue Launchpad plein écran."
        },
        "pkvsconf.launchpad.iconSize": {
          "type": "number",
          "default": 76,
          "minimum": 42,
          "maximum": 128,
          "description": "Taille des pictogrammes dans la vue Launchpad plein écran."
        },
        "pkvsconf.launchpad.theme": {
          "type": "string",
          "default": "sleek",
          "enum": [
            "sleek",
            "classic"
          ],
          "description": "Thème de la vue Launchpad plein écran."
        },
        "pkvsconf.launchpad.focusColor": {
          "type": "string",
          "default": "#008CFF",
          "pattern": "^#[0-9a-fA-F]{3}([0-9a-fA-F]{3})?$",
          "description": "Couleur du focus clavier dans la vue Launchpad plein écran."
        },
        "pkvsconf.launchpad.restorePanels": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "left",
            "right",
            "both"
          ],
          "enumDescriptions": [
            "Laisser les volets fermés",
            "Ouvrir le volet gauche",
            "Ouvrir le volet droit",
            "Ouvrir les deux volets"
          ],
          "description": "Volets à restaurer après la fermeture du Launchpad plein écran."
        },
        "pkvsconf.kanban.agentCommand": {
          "type": "string",
          "default": "opencode --prompt {prompt}",
          "description": "Commande lancée dans la session tmux d'une carte. Placeholders: {prompt}, {promptFile}, {title}."
        },
        "pkvsconf.kanban.tmuxCommand": {
          "type": "string",
          "default": "tmux",
          "description": "Nom ou chemin de l'exécutable tmux utilisé par le Kanban."
        }
      }
    },
    "commands": [
      {
        "command": "pkvsconf.kanbanOpen",
        "title": "Ouvrir le Kanban des agents",
        "category": "PK VS Conf",
        "icon": "$(terminal)"
      },
      {
        "command": "pkvsconf.kanbanOpenEditor",
        "title": "Ouvrir le Kanban dans l'éditeur",
        "category": "PK VS Conf",
        "icon": "$(go-to-editor)"
      },
      {
        "command": "pkvsconf.terminalSplitRight",
        "title": "Terminal: Split Right (PK)",
        "category": "PK VS Conf"
      },
      {
        "command": "pkvsconf.terminalSplitBottom",
        "title": "Terminal: Split Bottom (PK)",
        "category": "PK VS Conf"
      },
      {
        "command": "pkvsconf.terminalNewTab",
        "title": "Terminal: New Tab (PK)",
        "category": "PK VS Conf"
      },
      {
        "command": "revealInFinderButton.revealActive",
        "title": "Reveal Active File in Finder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "revealInFinderButton.refreshRootSize",
        "title": "Refresh Root Folder Size",
        "icon": "$(database)"
      },
      {
        "command": "revealInFinderButton.openRootFolderInFinder",
        "title": "Open Root Folder in Finder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "revealInFinderButton.openGitHubRepo",
        "title": "Open GitHub Repository",
        "icon": "$(github)"
      },
      {
        "command": "pkvsconf.addTagToExtension",
        "title": "Catégorie",
        "icon": "$(tag)"
      },
      {
        "command": "pkvsconf.searchExtensions",
        "title": "Rechercher des extensions",
        "icon": "$(search)"
      },
      {
        "command": "pkvsconf.codexCaptureResume",
        "title": "Codex: Capturer resume depuis le presse-papiers",
        "icon": "$(copy)"
      },
      {
        "command": "pkvsconf.codexSaveResume",
        "title": "Codex: Sauver un resume (manuel)",
        "icon": "$(save)"
      },
      {
        "command": "pkvsconf.codexPickResume",
        "title": "Codex: Reprendre (copier) un resume sauvegardé",
        "icon": "$(history)"
      },
      {
        "command": "pkvsconf.codexPickRecentSession",
        "title": "Codex: Reprendre une session récente (auto)",
        "icon": "$(history)"
      },
      {
        "command": "pkvsconf.codexSuggestSession",
        "title": "Codex: Suggérer la bonne session (transcript)",
        "icon": "$(search)"
      },
      {
        "command": "pkvsconf.regenerateWorkspaceTitlebarColor",
        "title": "Regenerer la couleur de la title bar",
        "icon": "$(refresh)"
      },
      {
        "command": "pkvsconf.previewActivePage",
        "title": "Preview de la page en cours",
        "icon": "$(open-preview)"
      },
      {
        "command": "pkvsconf.showExposedSecrets",
        "title": "Afficher les secrets exposés",
        "icon": "$(shield)"
      },
      {
        "command": "pkvsconf.rescanSecrets",
        "title": "Rescanner les secrets",
        "icon": "$(refresh)"
      },
      {
        "command": "pkvsconf.commitWithSecretCheck",
        "title": "Commit (vérification secrets)",
        "icon": "$(git-commit)"
      },
      {
        "command": "pkvsconf.createSkillsSymlink",
        "title": "Agent Skills",
        "icon": "$(link-external)"
      },
      {
        "command": "pkvsconf.launchpadOpen",
        "title": "Launchpad projets plein écran",
        "icon": "$(rocket)"
      },
      {
        "command": "pkvsconf.launchpadOpenList",
        "title": "Launchpad projets: liste",
        "icon": "$(list-unordered)"
      },
      {
        "command": "pkvsconf.launchpadAddCurrent",
        "title": "Ajouter le projet courant au Launchpad",
        "icon": "$(add)"
      },
      {
        "command": "pkvsconf.launchpadAddFolder",
        "title": "Ajouter un dossier au Launchpad",
        "icon": "$(folder-add)"
      },
      {
        "command": "pkvsconf.launchpadRevealInFinder",
        "title": "Révéler le projet dans le Finder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "pkvsconf.launchpadToggleViewMode",
        "title": "Launchpad: Basculer le mode d'affichage",
        "icon": "$(layout)"
      },
      {
        "command": "pkvsconf.launchpadRemove",
        "title": "Launchpad: Retirer un projet",
        "icon": "$(remove)"
      },
      {
        "command": "pkvsconf.agentHistoryAddFromClipboard",
        "title": "Agent History: Ajouter depuis le presse-papiers",
        "icon": "$(add)"
      },
      {
        "command": "pkvsconf.agentHistoryRun",
        "title": "Agent History: Lancer (depuis l'historique)",
        "icon": "$(play)"
      },
      {
        "command": "pkvsconf.agentHistoryClear",
        "title": "Agent History: Vider l'historique",
        "icon": "$(trash)"
      },
      {
        "command": "pkvsconf.openInDefaultBrowser",
        "title": "Ouvrir avec Chrome",
        "icon": "$(browser)"
      },
      {
        "command": "pkvsconf.addToGitignore",
        "title": "⛔ Ajouter au .gitignore",
        "icon": "$(exclude)"
      }
    ],
    "colors": [
      {
        "id": "pkvsconf.rootSizeStatusBarItem.background",
        "description": "Background color for the Root size status bar item.",
        "defaults": {
          "light": "#2A9D8F",
          "dark": "#1E7067",
          "highContrast": "#00A896"
        }
      },
      {
        "id": "pkvsconf.rootSizeStatusBarItem.foreground",
        "description": "Foreground color for the Root size status bar item.",
        "defaults": {
          "light": "#FFFFFF",
          "dark": "#FFFFFF",
          "highContrast": "#FFFFFF"
        }
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "agentHistoryView",
          "name": "Agent History",
          "icon": "$(history)"
        },
        {
          "id": "extensionTagsView",
          "name": "PK Extensions",
          "type": "webview",
          "icon": "$(tag)"
        },
        {
          "id": "launchpadExplorerView",
          "name": "Launchpad Projets",
          "type": "webview",
          "collapsed": false,
          "icon": "$(rocket)"
        },
        {
          "id": "projectIconView",
          "name": "Project Icon",
          "type": "webview",
          "collapsed": false,
          "visibility": "visible",
          "icon": "$(symbol-color)"
        }
      ],
      "pkvsconfRightSidebar": [
        {
          "id": "projectNotesView",
          "name": "Notes Projet",
          "type": "webview",
          "collapsed": false,
          "icon": "$(note)"
        }
      ],
      "pkvsconfNotesContainer": []
    },
    "menus": {
      "commandPalette": [
        {
          "command": "revealInFinderButton.openGitHubRepo"
        },
        {
          "command": "pkvsconf.addTagToExtension"
        },
        {
          "command": "pkvsconf.codexCaptureResume"
        },
        {
          "command": "pkvsconf.codexPickResume"
        },
        {
          "command": "pkvsconf.codexPickRecentSession"
        },
        {
          "command": "pkvsconf.codexSuggestSession"
        },
        {
          "command": "pkvsconf.regenerateWorkspaceTitlebarColor"
        },
        {
          "command": "pkvsconf.createSkillsSymlink"
        },
      {
        "command": "pkvsconf.openInDefaultBrowser",
        "when": "resourceExtname =~ /\\.html?$/"
      },
      {
        "command": "pkvsconf.addToGitignore",
        "when": "false"
      }
    ],
      "extension/context": [
        {
          "command": "pkvsconf.addTagToExtension",
          "when": "extensionIsInstalled",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "pkvsconf.openInDefaultBrowser",
          "when": "resourceExtname =~ /\\.html?$/",
          "group": "navigation@2"
        },
        {
          "command": "pkvsconf.addToGitignore",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "pkvsconf.openInDefaultBrowser",
          "when": "resourceExtname =~ /\\.html?$/",
          "group": "navigation@2"
        }
      ],
      "scm/title": [
        {
          "command": "revealInFinderButton.openGitHubRepo",
          "group": "navigation"
        },
        {
          "command": "pkvsconf.commitWithSecretCheck",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "view/title": [
        {
          "command": "revealInFinderButton.revealActive",
          "when": "view == workbench.explorer.fileView && isMac",
          "group": "navigation"
        },
        {
          "command": "pkvsconf.createSkillsSymlink",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation"
        },
        {
          "command": "pkvsconf.launchpadOpen",
          "when": "view == projectIconView",
          "group": "navigation"
        },
        {
          "command": "pkvsconf.launchpadAddCurrent",
          "when": "view == projectIconView",
          "group": "navigation"
        },
        {
          "command": "revealInFinderButton.openGitHubRepo",
          "when": "view == workbench.scm",
          "group": "navigation"
        },
        {
          "command": "pkvsconf.searchExtensions",
          "when": "view == extensionTagsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "pkvsconf.addTagToExtension",
          "when": "view == extensionTagsView && viewItem == extensionListItem",
          "group": "inline"
        },
        {
          "command": "pkvsconf.launchpadOpen",
          "when": "view == launchpadExplorerView && viewItem == launchpadProject",
          "group": "navigation"
        },
        {
          "command": "pkvsconf.launchpadRevealInFinder",
          "when": "view == launchpadExplorerView && viewItem == launchpadProject",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pkvsconf.terminalSplitRight",
        "key": "cmd+d",
        "when": "terminalFocus"
      },
      {
        "command": "pkvsconf.terminalSplitBottom",
        "key": "cmd+shift+d",
        "when": "terminalFocus"
      },
      {
        "command": "pkvsconf.terminalNewTab",
        "key": "cmd+t",
        "when": "terminalFocus"
      },
      {
        "command": "pkvsconf.commitWithSecretCheck",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "scmRepository"
      },
      {
        "command": "pkvsconf.launchpadOpen",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      },
      {
        "command": "pkvsconf.launchpadOpenList",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      },
      {
        "command": "pkvsconf.launchpadAddCurrent",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c"
      },
      {
        "command": "pkvsconf.launchpadAddFolder",
        "key": "ctrl+alt+shift+f",
        "mac": "cmd+alt+shift+f"
      },
      {
        "command": "pkvsconf.launchpadRevealInFinder",
        "key": "ctrl+alt+shift+r",
        "mac": "cmd+alt+shift+r"
      },
      {
        "command": "pkvsconf.launchpadRemove",
        "key": "ctrl+alt+shift+backspace",
        "mac": "cmd+alt+shift+backspace"
      },
      {
        "command": "pkvsconf.openInDefaultBrowser",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && resourceExtname =~ /\\.html?$/"
      },
      {
        "command": "pkvsconf.openInDefaultBrowser",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "when": "listFocus && resourceExtname =~ /\\.html?$/"
      }
    ]
  },
  "scripts": {
    "ensure:version-bump": "node ./scripts/ensure-version-bump.mjs",
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "mkdir -p ../release && vsce package -o ../release/${npm_package_name}-${npm_package_version}.vsix",
    "release": "npm run ensure:version-bump && npm run build && npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.5.4"
  }
}
